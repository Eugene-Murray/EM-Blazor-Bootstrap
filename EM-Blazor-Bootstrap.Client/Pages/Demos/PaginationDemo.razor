@page "/wasm/pagination"
@layout DocsLayout
@rendermode InteractiveWebAssembly

<PageTitle>Pagination (WASM) – EM Bootstrap</PageTitle>

<div class="d-flex align-items-start justify-content-between mb-1">
	<h1 class="h2 mb-0">Pagination</h1>
	<span class="badge text-bg-primary">WebAssembly</span>
</div>
<p class="lead text-body-secondary mb-4">
	<code>EmPagination</code> running in WebAssembly. Page navigation state is managed entirely in the browser.
</p>
<div class="alert alert-primary d-flex gap-2 mb-5">
	<span>🌐</span>
	<span>This page uses <strong><code>@@rendermode InteractiveWebAssembly</code></strong>. Navigate pages — no server calls are made.</span>
</div>

<DemoSection Title="Basic Pagination (WASM)">
	<Preview>
		<EmPagination CurrentPage="@_page1" TotalPages="10" OnPageChanged="p => _page1 = p" />
		<p class="text-body-secondary small mt-2 mb-0">Current page: @_page1 — state managed in WASM</p>
	</Preview>
</DemoSection>

<DemoSection Title="Ellipsis Windowing (WASM)">
	<Preview>
		<EmPagination CurrentPage="@_page2" TotalPages="50" OnPageChanged="p => _page2 = p" />
		<p class="text-body-secondary small mt-2 mb-0">Page @_page2 of 50</p>
	</Preview>
</DemoSection>

<DemoSection Title="Paged Data (WASM)" Description="Filtering and slicing the data array runs in WASM — no API call needed.">
	<Preview>
		<EmPagination CurrentPage="@_pagedPage" TotalPages="@TotalPages" OnPageChanged="p => _pagedPage = p" Align="center" />
		@foreach (var item in PagedItems)
		{
			<div class="border rounded p-2 mb-2 d-flex justify-content-between">
				<span>@item</span>
				<EmBadge Variant="primary" Pill>WASM</EmBadge>
			</div>
		}
	</Preview>
</DemoSection>

<div class="mt-4">
	<a href="/components/pagination" class="btn btn-outline-success btn-sm">View Interactive Server version →</a>
</div>

@code {
	private int _page1 = 1;
	private int _page2 = 5;
	private int _pagedPage = 1;

	private const int PageSize = 3;
	private readonly string[] _allItems = Enumerable.Range(1, 15).Select(i => $"Item #{i}").ToArray();
	private int TotalPages => (int)Math.Ceiling(_allItems.Length / (double)PageSize);
	private IEnumerable<string> PagedItems => _allItems.Skip((_pagedPage - 1) * PageSize).Take(PageSize);
}
