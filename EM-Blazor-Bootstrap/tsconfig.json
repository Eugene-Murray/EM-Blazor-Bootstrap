{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2020",
    "moduleResolution": "bundler",
    "strict": true,
    "outDir": "wwwroot/js",
    "rootDir": "Scripts",
    "sourceMap": false,
    "removeComments": true
  },
  "include": [
    "Scripts/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "wwwroot"
  ]
}
